# ---------------------------------------------------------------------------
# rConfig V8 Core - Docker environment
#
# Copy this file to .env and review every value marked [EDIT] before going
# live. This file is bind mounted into the container as the application's .env,
# so it holds both the Docker settings and the Laravel application settings.
#
# Storage location: the device config backups, logs and keys live in the
# container's storage/ directory, which docker-compose.yml persists. By default
# that is a Docker named volume (storage_data). To keep storage on a visible
# host path instead, switch to the bind mount option in docker-compose.yml.
# The storage path is set there, not here.
# ---------------------------------------------------------------------------

# Prebuilt image version to run. Pin to a release (recommended) or use "latest".
# See https://hub.docker.com/r/rconfig/rconfig/tags for available versions. [EDIT]
RCONFIG_VERSION=8.3.0

# --- Application ---------------------------------------------------------
APP_NAME="rConfig V8 Core"
APP_ENV=production
# Leave APP_KEY empty on a brand new install: the container generates it on
# first start and writes it back here. Never change it for an existing
# database, or encrypted values (device credentials) will fail to decrypt.
APP_KEY=
APP_DEBUG=false
# Set to the URL users browse to, including the port if not 80/443. [EDIT]
APP_URL=http://localhost:8080
APP_DIR_PATH=/var/www/html/rconfig

# Host port the app is published on. Change if 8080 is already in use. [EDIT]
APP_PORT=8080

LOG_CHANNEL=daily
LOG_LEVEL=warning

# --- Database ------------------------------------------------------------
# Change every password below before any real use. [EDIT]
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rconfig
DB_USERNAME=rconfig_user
DB_PASSWORD=rconfig_pass
MYSQL_ROOT_PASSWORD=root_password
# Host port the database is published on (for external DB tools). [EDIT]
DB_PORT_HOST=3307

# --- Cache / queue / session (Redis) ------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
CACHE_PREFIX=rConfigp
QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
REDIS_QUEUE_RETRY_AFTER=130
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Horizon (queue workers) --------------------------------------------
HORIZON_PREFIX=rConfig
HORIZON_LOCAL_TIMEOUT=120
HORIZON_PROD_TIMEOUT=120
HORIZON_MIN_PROCESS=1
HORIZON_MAX_PROCESS=10
HORIZON_DEFAULT_MAX_PROCESS=5

# --- Mail ----------------------------------------------------------------
# Defaults route mail to the log. Point at a real SMTP host for notifications.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@rconfig.local
MAIL_FROM_NAME=rConfig

# --- rConfig -------------------------------------------------------------
RCONFIG_API_TOKEN=V8Core
RCONFIG_SUB_ID="V8Core"
RCONFIG_SUB_NAME="V8Core"
RCONFIG_SUB_STATUS="Active"
RCONFIG_SUB_EXPIRY="N/A"
MASK_DEVICE_CREDENTIALS=false

# Set to your local timezone. [EDIT]
TIMEZONE=Europe/Dublin

ENLIGHTN_SKIP_ENVIRONMENT_SPECIFIC=false

# --- Single sign-on (optional) ------------------------------------------
# Uncomment and fill in only if you use SSO. See the docs for each provider.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=
# MICROSOFT_TENANT_ID=
# OKTA_BASE_URL=
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_REDIRECT_URI=
# SAML2_METADATA_URL=
# SAML2_SP_CERTIFICATE=
# SAML2_SP_PRIVATE_KEY=
